---
export interface Props {
	currentPage: number;
	totalPages: number;
}

const { currentPage, totalPages } = Astro.props;

function getPageUrl(page: number) {
	if (page === 1) return '/';
	return `/page/${page}`;
}

const prevUrl = currentPage > 1 ? getPageUrl(currentPage - 1) : null;
const nextUrl = currentPage < totalPages ? getPageUrl(currentPage + 1) : null;

// 生成页码列表（显示当前页前后2页）
const pages: (number | string)[] = [];
for (let i = 1; i <= totalPages; i++) {
	if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
		pages.push(i);
	} else if (pages[pages.length - 1] !== '...') {
		pages.push('...');
	}
}
---

<nav class="flex justify-center items-center gap-2 mt-8 mb-4" aria-label="分页导航">
	{prevUrl ? (
		<a href={prevUrl} class="px-3 py-2 rounded-md text-sm text-gray-600 hover:bg-gray-100 transition-colors">
			← 上一页
		</a>
	) : (
		<span class="px-3 py-2 rounded-md text-sm text-gray-300 cursor-not-allowed">← 上一页</span>
	)}

	{pages.map((page) =>
		page === '...' ? (
			<span class="px-2 py-2 text-sm text-gray-400">...</span>
		) : page === currentPage ? (
			<span class="px-3 py-2 rounded-md text-sm bg-gray-800 text-white font-medium">{page}</span>
		) : (
			<a href={getPageUrl(page as number)} class="px-3 py-2 rounded-md text-sm text-gray-600 hover:bg-gray-100 transition-colors">
				{page}
			</a>
		)
	)}

	{nextUrl ? (
		<a href={nextUrl} class="px-3 py-2 rounded-md text-sm text-gray-600 hover:bg-gray-100 transition-colors">
			下一页 →
		</a>
	) : (
		<span class="px-3 py-2 rounded-md text-sm text-gray-300 cursor-not-allowed">下一页 →</span>
	)}
</nav>
